{
    "id": "cmd_injection_journey_v5",
    "title": "Command Injection: The Complete Journey",
    "description": "A 6-stage simulated attack against Acme Corp. Persistent OS environment. Prove your compromise through evidence.",
    "osState": {
        "filesystem": {
            "/": { "type": "dir", "contents": ["home", "var", "etc", "opt", "root", "tmp"] },
            "/tmp": { "type": "dir", "contents": [] },
            "/root": { "type": "dir", "contents": [".ssh", "evidence.txt"] },
            "/root/.ssh": { "type": "dir", "contents": ["id_rsa"] },
            "/root/.ssh/id_rsa": { "type": "file", "content": "-----BEGIN RSA PRIVATE KEY-----\nMIIEowIBAAKCAQEAw7...\n(Root Private Key Evidence)\n-----END RSA PRIVATE KEY-----" },
            "/root/evidence.txt": { "type": "file", "content": "You have achieved root access. The system is fully compromised." },
            "/home": { "type": "dir", "contents": ["user"] },
            "/home/user": { "type": "dir", "contents": [] },
            "/var": { "type": "dir", "contents": ["www", "db", "log"] },
            "/var/db": { "type": "dir", "contents": ["employee.db"] },
            "/var/db/employee.db": { "type": "file", "content": "SQLite format 3\nuser_id,username,password_hash\n1,admin,$2y$10$wT8KzQ8J7y\n2,dev,$2y$10$xyz123" },
            "/var/log": { "type": "dir", "contents": ["apache2"] },
            "/var/log/apache2": { "type": "dir", "contents": ["access.log", "error.log"] },
            "/var/log/apache2/access.log": { "type": "file", "content": "127.0.0.1 - - [21/Jun/2026:10:00:01 +0000] \"GET / HTTP/1.1\" 200" },
            "/var/www": { "type": "dir", "contents": ["html"] },
            "/var/www/html": { "type": "dir", "contents": ["index.php", "config.php", "uploads"] },
            "/var/www/html/index.php": { "type": "file", "content": "<?php echo 'Ping Utility'; ?>" },
            "/var/www/html/config.php": { "type": "file", "content": "<?php\n// Internal Config\n$db_host = '127.0.0.1';\n$db_user = 'root';\n$db_pass = 'sUp3r_s3cr3t_p4ss';\n?>" },
            "/var/www/html/uploads": { "type": "dir", "contents": [] },
            "/etc": { "type": "dir", "contents": ["passwd", "shadow"] },
            "/etc/passwd": { "type": "file", "content": "root:x:0:0:root:/root:/bin/bash\nwww-data:x:33:33:www-data:/var/www:/usr/sbin/nologin" },
            "/etc/shadow": { "type": "file", "content": "root:$6$xyz$abc:18000:0:99999:7:::" },
            "/opt": { "type": "dir", "contents": ["scripts"] },
            "/opt/scripts": { "type": "dir", "contents": ["backup.sh"] },
