{
    "id": "cmd_injection_journey_v4",
    "title": "Command Injection Mastery Journey",
    "description": "A 3-stage simulated attack against Acme Corp. Persistent OS environment.",
    "missions": [
        {
            "id": "mission_1_recon",
            "title": "Initial Foothold",
            "scenario": {
                "company": "Acme Corp",
                "target": "Network Diagnostic Utility",
                "difficulty": "Easy",
                "estimated_time": "10 min",
                "skills": ["Linux", "HTTP", "Basic Networking"],
                "story": "Acme Corp uses a network diagnostic tool. We believe it's vulnerable to Command Injection. Start by exploring the server and locating the database password inside config.php.",
                "objective": "Read /var/www/html/config.php to find the DB password.",
                "environment": {
                    "os": "Linux",
                    "web": "Apache",
                    "lang": "PHP"
                },
                "osState": {
                    "filesystem": {
                        "/": { "type": "dir", "contents": ["home", "var", "etc", "opt", "root"] },
                        "/root": { "type": "dir", "contents": ["flag.txt"] },
                        "/root/flag.txt": { "type": "file", "content": "FLAG{r00t_pr1v_3sc_m4st3r}" },
                        "/home": { "type": "dir", "contents": ["user"] },
                        "/home/user": { "type": "dir", "contents": [] },
                        "/var": { "type": "dir", "contents": ["www", "db"] },
                        "/var/db": { "type": "dir", "contents": ["employee.db"] },
                        "/var/db/employee.db": { "type": "file", "content": "SQLite format 3\nadmin: FLAG{l4t3r4l_m0v3_1337}" },
                        "/var/www": { "type": "dir", "contents": ["html"] },
                        "/var/www/html": { "type": "dir", "contents": ["index.php", "config.php", "uploads"] },
                        "/var/www/html/index.php": { "type": "file", "content": "<?php echo 'Ping Utility'; ?>" },
                        "/var/www/html/config.php": { "type": "file", "content": "<?php\n// Internal Config\n$db_host = '127.0.0.1';\n$db_user = 'root';\n$db_pass = 'sUp3r_s3cr3t_p4ss';\n?>" },
                        "/var/www/html/uploads": { "type": "dir", "contents": [] },
                        "/etc": { "type": "dir", "contents": ["passwd"] },
                        "/etc/passwd": { "type": "file", "content": "root:x:0:0:root:/root:/bin/bash\nwww-data:x:33:33:www-data:/var/www:/usr/sbin/nologin" },
                        "/opt": { "type": "dir", "contents": ["scripts"] },
                        "/opt/scripts": { "type": "dir", "contents": ["backup.sh"] },
                        "/opt/scripts/backup.sh": { "type": "file", "content": "#!/bin/bash\necho 'Backing up employee database...'\ncat /var/db/employee.db > /var/db/backup.sql" }
                    },
                    "currentUser": "www-data",
                    "env": {
                        "PATH": "/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin",
                        "HOME": "/var/www",
                        "USER": "www-data",
                        "PWD": "/var/www/html",
                        "SHELL": "/bin/bash"
                    },
                    "processes": [
                        { "pid": 1, "user": "root", "cmd": "/sbin/init" },
                        { "pid": 501, "user": "root", "cmd": "/usr/sbin/sshd -D" },
                        { "pid": 1024, "user": "root", "cmd": "apache2 -k start" },
                        { "pid": 1025, "user": "www-data", "cmd": "apache2 -k start" },
                        { "pid": 2040, "user": "root", "cmd": "cron" }
                    ],
                    "network": {
                        "interfaces": [
                            { "name": "lo", "ip": "127.0.0.1", "mask": "255.0.0.0" },
                            { "name": "eth0", "ip": "10.10.10.5", "mask": "255.255.255.0" }
                        ],
                        "ports": [
                            { "proto": "tcp", "local": "0.0.0.0:80", "state": "LISTEN", "pid": "1024/apache2" },
                            { "proto": "tcp", "local": "0.0.0.0:22", "state": "LISTEN", "pid": "501/sshd" }
                        ],
                        "hostname": "acme-web-prod"
                    }
                },
                "completionCondition": "history.some(h => h.output && h.output.includes('sUp3r_s3cr3t_p4ss'))"
            },
            "hints": [
                { "cost": 5, "text": "Start by listing the contents of the current directory using `ls -la`" },
                { "cost": 10, "text": "Use `cat config.php` combined with the command injection syntax `; cat config.php`." }
            ],
            "rewards": { "xp": 100, "coins": 20 }
        },
